  prog "SuperTux 2"  "/usr/share/icons/hicolor/scalable/apps/supertux2.svg"           supertux2
}

menu "Multimedia" folder {
  prog "OBS Studio"        "/usr/share/icons/hicolor/512x512/apps/com.obsproject.Studio.png"  obs
  prog "VLC media player"  "/usr/share/icons/hicolor/256x256/apps/vlc.png"                    vlc
}

menu "Wine" folder {
  menu "User-installed apps" folder {
    menu "Gaming" folder {
      menu "Emulation" folder {
        prog "Snes9x"  -  wine /home/<user>/wine/drive_c/users/<user>/Desktop/snes9x/snes9x-x64.exe
      }
      separator
      prog "Battle.net"               "~/.local/share/icons/hicolor/256x256/apps/FC6C_Battle.net.0.png"      wine /home/<user>/.wine/drive_c/Program\ Files\ \(x86\)/Battle.net/Battle.net.exe
      prog "GTA San Andreas"          -                                                                      wine /home/<user>/wine/drive_c/Program\ Files\ \(x86\)/Rockstar\ Games/GTA\ San\ Andreas/gta_sa.exe
      prog "HoYoPlay"                 "~/.local/share/icons/hicolor/256x256/apps/B0B4_launcher.0.png"        wine /home/<user>/wine/drive_c/Program\ Files/HoYoPlay/launcher.exe
      prog "Rockstar Games Launcher"  "~/.local/share/icons/hicolor/256x256/apps/BA95_Launcher.0.png"        wine /home/<user>/wine/drive_c/Program\ Files/Rockstar\ Games/Launcher/Launcher.exe 
      prog "Steam"                    "~/.local/share/icons/hicolor/256x256/apps/E523_steam.0.png"           wine /home/<user>/wine/drive_c/Program\ Files\ \(x86\)/Steam/steam.exe
      prog "Ubisoft Connect"          "~/.local/share/icons/hicolor/256x256/apps/F24A_UbisoftConnect.0.png"  wine /home/<user>/wine/drive_c/Program\ Files\ \(x86\)/Ubisoft/Ubisoft\ Game\ Launcher/UbisoftConnect.exe
    }
    prog "LiveSplit"  -  wine /home/<user>/wine/drive_c/users/<user>/Desktop/LiveSplit/LiveSplit.exe
  }
  menu "Pre-installed apps" folder {
    prog "notepad"      "/usr/share/icons/hicolor/scalable/apps/wine-notepad.svg"      wine notepad
    prog "regedit"      -                                                              wine regedit
    prog "taskmgr"      -                                                              wine taskmgr
    prog "uninstaller"  "/usr/share/icons/hicolor/scalable/apps/wine-uninstaller.svg"  wine uninstaller
  }
  separator
  prog "winecfg"     "/usr/share/icons/hicolor/scalable/apps/wine-winecfg.svg"  winecfg
  prog "winetricks"  "/usr/share/icons/hicolor/scalable/apps/winetricks.svg"    winetricks
}

menu "System" folder {
  menu "Utility" folder {
    prog "Blueman"               "/usr/share/icons/hicolor/scalable/apps/blueman.svg"         blueman-manager
    prog "kitty"                 "/usr/share/icons/hicolor/scalable/apps/kitty.svg"           kitty
    prog "MControlCenter"        "/usr/share/icons/hicolor/scalable/apps/mcontrolcenter.svg"  mcontrolcenter
    prog "NVIDIA Control Panel"  -                                                            nvidia-settings --load-config-only
  }
  separator
  prog "Xfe"  "/usr/share/icons/hicolor/scalable/apps/xfe.svg"  xfe
  prog "Xfi"  "/usr/share/icons/hicolor/scalable/apps/xfi.svg"  xfi
  prog "Xfp"  "/usr/share/icons/hicolor/scalable/apps/xfp.svg"  xfp
  prog "Xfw"  "/usr/share/icons/hicolor/scalable/apps/xfw.svg"  xfw
}


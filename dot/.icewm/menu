prog gentoo-wiki $HOME/.icewm/assets/gentoo-signet.svg google-chrome-stable "https://wiki.gentoo.org/wiki/"
separator

menu www folder {
  prog daedalus - ~/.daedalus/mainnet/bin/daedalus
  prog chrome /usr/share/icons/hicolor/256x256/apps/google-chrome.png google-chrome-stable
}

menu development folder {
  prog geany /usr/share/icons/hicolor/scalable/apps/geany.svg geany
}

menu editing folder {
  prog blender /usr/share/icons/hicolor/scalable/apps/blender-5.0.svg blender-5.0
  prog freecad /usr/share/icons/hicolor/64x64/apps/org.freecad.FreeCAD.png FreeCAD
  prog gimp /usr/share/icons/hicolor/scalable/apps/gimp.svg gimp
  prog libreoffice /usr/share/icons/hicolor/scalable/apps/libreoffice25.8-base.svg libreoffice-bin
}

menu gaming folder {
  prog minecraft /usr/share/icons/hicolor/scalable/apps/minecraft-launcher.svg minecraft-launcher
  prog steam /usr/share/icons/hicolor/256x256/apps/steam.png steam
  prog supertux2 /usr/share/icons/hicolor/scalable/apps/supertux2.svg supertux2
}

menu multimedia folder {
  prog obs /usr/share/icons/hicolor/512x512/apps/com.obsproject.Studio.png obs
  prog vlc /usr/share/icons/hicolor/256x256/apps/vlc.png vlc
}

menu wine folder {
  prog gta-sa - wine ".wine/drive_c/Program Files (x86)/Rockstar Games/GTA San Andreas/gta_sa.exe"
  prog hoyoplay - wine ".wine/drive_c/Program Files/HoYoPlay/launcher.exe"
  prog rockstar-games-launcher - wine ".wine/drive_c/Program Files/Rockstar Games/Launcher/Launcher.exe" 
  prog ubisoft-connect - wine ".wine/drive_c/Program Files (x86)/Ubisoft/Ubisoft Game Launcher/UbisoftConnect.exe"
  separator
  prog winetricks /usr/share/icons/hicolor/scalable/apps/winetricks.svg winetricks
}

menu system folder {
  prog kitty /usr/share/icons/hicolor/scalable/apps/kitty.svg kitty
  prog mcontrolcenter /usr/share/icons/hicolor/scalable/apps/mcontrolcenter.svg mcontrolcenter
  prog nvidia-xserver - nvidia-settings
  separator
  prog xfe /usr/share/icons/hicolor/scalable/apps/xfe.svg xfe
  prog xfi /usr/share/icons/hicolor/scalable/apps/xfi.svg xfi
  prog xfp /usr/share/icons/hicolor/scalable/apps/xfp.svg xfp
  prog xfw /usr/share/icons/hicolor/scalable/apps/xfw.svg xfw
}

separator
menuprog "all apps" folder icewm-menu-fdo

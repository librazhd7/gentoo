  menu "Emulation" folder {
    prog "puNES"   "/usr/share/icons/hicolor/512x512/apps/io.github.punesemu.puNES.png"  punes
    prog "PCSX2"   -                                                                     pcsx2-qt
    prog "PPSSPP"  "/usr/share/icons/hicolor/scalable/apps/ppsspp.svg"                   PPSSPPSDL
    prog "RPCS3"   "/usr/share/icons/hicolor/scalable/apps/rpcs3.svg"                    rpcs3
  }

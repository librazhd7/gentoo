  menu "Installed apps" folder {
    prog "Battle.net" $HOME/.local/share/icons/hicolor/256x256/apps/FC6C_Battle.net.0.png wine "$HOME/.wine/drive_c/Program Files (x86)/Battle.net/Battle.net.exe"

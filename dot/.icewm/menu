    prog "LibreOffice Impress"  "/usr/share/icons/hicolor/scalable/apps/libreoffice25.8-impress.svg"  libreoffice-bin --impress
    prog "LibreOffice Math"     "/usr/share/icons/hicolor/scalable/apps/libreoffice25.8-math.svg"     libreoffice-bin --math
    prog "LibreOffice Writer"   "/usr/share/icons/hicolor/scalable/apps/libreoffice25.8-writer.svg"   libreoffice-bin --writer
  }
  separator
  prog "Blender"                         "/usr/share/icons/hicolor/scalable/apps/blender-5.0.svg"       blender-5.0
